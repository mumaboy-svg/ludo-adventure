.page-shell { min-height:100vh; position:relative; overflow:hidden; }
.page-bg { position:absolute; inset:0; width:100%; height:100%; z-index:0; }
.content { position:relative; z-index:1; min-height:100vh; padding:28rpx; }
.player-row { display:flex; align-items:center; gap:12rpx; }
input, .picker { flex:1; min-height:76rpx; background:rgba(255,255,255,.9); border-radius:18rpx; padding:0 18rpx; display:flex; align-items:center; }
.small { width:120rpx; font-size:24rpx; padding:0; }
.actions button { flex:1; min-width:200rpx; }
