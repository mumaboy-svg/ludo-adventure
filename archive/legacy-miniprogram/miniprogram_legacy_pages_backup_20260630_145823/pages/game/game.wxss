.game { background:#f5ecd9; }
.board-card { padding: 14rpx; background:#fff; border-radius:28rpx; margin-bottom:20rpx; }
.board { position:relative; width:100%; aspect-ratio:1/1; }
.board-img { width:100%; height:100%; }
.piece { position:absolute; transform:translate(-50%, -50%); display:flex; align-items:center; gap:4rpx; }
.piece image { width:48rpx; height:48rpx; }
.piece text { background:rgba(0,0,0,.65); color:#fff; border-radius:10rpx; padding:2rpx 8rpx; font-size:20rpx; font-weight:900; }
.dice { width:120rpx; height:120rpx; border-radius:24rpx; background:#fff; display:flex; align-items:center; justify-content:center; font-size:58rpx; font-weight:1000; margin:20rpx auto; box-shadow:0 12rpx 24rpx rgba(0,0,0,.14); }
.actions button { flex:1; min-width:180rpx; }
.log-box { margin-top:20rpx; background:#211b18; color:#fff4df; border-radius:20rpx; padding:16rpx; max-height:220rpx; overflow:auto; }
.log-line { font-size:24rpx; line-height:1.6; }
.modal-mask { position:fixed; inset:0; background:rgba(0,0,0,.55); display:flex; align-items:center; justify-content:center; padding:40rpx; }
.modal-card { width:100%; background:#fff7df; border-radius:32rpx; padding:32rpx; }
.section-title { font-size:34rpx; font-weight:1000; margin-bottom:18rpx; }
